{% extends 'base.html.twig' %}

{% block title %}Game{% endblock %}

{% block body %}

<div class="header">

    <h1>My Uno</h1>
    <a href="{{ path('app_home') }}">
        <div class="btn btn-quit">Quitter</div>
    </a>

</div>

<div class = "table">

    <div class ="top">
        <div class="player-info">
            <img src="{{ asset(game.currentTurn == 2 ? 'images/user-play.png' : 'images/user.png') }}" alt="Joueur 2" class="avatar">
            <span>Joueur 2</span>
        </div>
        <div class = "hand hand-top">
            {% for card in game.handEnemy2 %}
                <div class="card back"></div>
            {% endfor %}
        </div>
    </div>

     <div class = "middle">
        <div class="side side-left">
            <div class="player-info">
                <img src="{{ asset(game.currentTurn == 1 ? 'images/user-play.png' : 'images/user.png') }}" alt="Joueur 1" class="avatar">
                <span>Joueur 1</span>
            </div>
            <div class="hand hand-left">
                {% for card in game.handEnemy1 %}
                    <div class="card back"></div>
                {% endfor %}
            </div>
        </div>

        <div class = "pile">
            <div class="card {{ pileCard.color }} {% if pileCard.number == 'R' %}reverse{% endif %}">{{ pileCard.number }}</div>
        </div>

        <div class="side side-right">
            <div class="hand hand-right">
                {% for card in game.handEnemy3 %}
                    <div class="card back"></div>
                {% endfor %}
            </div>
            <div class="player-info">
                <img src="{{ asset(game.currentTurn == 3 ? 'images/user-play.png' : 'images/user.png') }}" alt="Joueur 3" class="avatar">
                <span>Joueur 3</span>
            </div>
        </div>
    </div>

    <div class = "bottom">
        <h2 class="player-title">Mon jeu</h2>
        <div class="hand hand-player">
            {% for index, card in game.handPlayer %}
                {% if card in playableCards %}
                    <a href="{{ path('app_player', {id: game.id, card: index}) }}">
                        <div class="card {{ card.color }} playable {% if card.number == 'R' %}reverse{% endif %}">{{ card.number }}</div>
                    </a>
                {% else %}
                    <div class="card {{ card.color }} {% if card.number == 'R' %}reverse{% endif %}">{{ card.number }}</div>
                {% endif %}
            {% endfor %}

            {% if game.currentTurn == 0 and playableCards is empty %}
                <a href="{{ path('app_draw', {id: game.id}) }}">
                    <div class="btn draw">Piocher</div>
                </a>
            {% endif %}
        </div>

    </div>

</div>

{% if game.currentTurn != 0 %}
    <script>
        setTimeout(function () {
            window.location.href = "{{ path('app_ennemy', {id: game.id, enemy: game.currentTurn}) }}";
        }, 2000);
    </script>
{% endif %}

{% endblock %}